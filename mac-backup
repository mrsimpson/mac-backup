#!/usr/bin/env node

// Parse global flags before subcommand
const args = process.argv.slice(2);

for (const flag of ['--dry-run', '--yes']) {
  const idx = args.indexOf(flag);
  if (idx !== -1) {
    const envName = flag.slice(2).replace(/-/g, '_').toUpperCase();
    process.env[envName] = 'true';
    args.splice(idx, 1);
  }
}

const [cmd] = args;

switch (cmd) {
  case 'config': {
    const { runConfig } = await import('./src/commands/config.js');
    await runConfig();
    break;
  }
  case 'backup': {
    const { runBackup } = await import('./src/commands/backup.js');
    await runBackup();
    break;
  }
  case 'restore': {
    const { runRestore } = await import('./src/commands/restore.js');
    await runRestore();
    break;
  }
  default:
    console.log('Usage: mac-backup [--dry-run] [--yes] <config|backup|restore>');
    console.log('  config   — interactive setup wizard');
    console.log('  backup   — run backup');
    console.log('  restore  — restore from backup');
    process.exit(cmd ? 1 : 1);
}
